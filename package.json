{
  "name": "whatsapp-chat-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "Production-ready WhatsApp-style real-time chat application",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "smoke:release-a": "node scripts/release-a-smoke.mjs",
    "smoke:release-b-account": "node scripts/release-b-account-smoke.mjs",
    "smoke:release-b-safety": "node scripts/release-b-safety-smoke.mjs",
    "smoke:release-b-operations": "node scripts/release-b-operations-smoke.mjs",
    "smoke:release-c-moments": "node scripts/release-c-moments-smoke.mjs",
    "smoke:release-c-moment-interactions": "node scripts/release-c-moment-interactions-smoke.mjs",
    "smoke:release-d-profiles": "node scripts/release-d-profiles-smoke.mjs",
    "smoke:release-d-feed": "node scripts/release-d-feed-smoke.mjs",
    "smoke:release-d-communities": "node scripts/release-d-communities-smoke.mjs",
    "smoke:release-d-discovery": "node scripts/release-d-discovery-smoke.mjs",
    "smoke:release-d-for-you": "node scripts/release-d-for-you-smoke.mjs",
    "smoke:release-e-video-foundation": "node scripts/release-e-video-foundation-smoke.mjs",
    "smoke:release-e-reels-viewer": "node scripts/release-e-reels-viewer-smoke.mjs",
    "smoke:release-e-reels-for-you": "node scripts/release-e-reels-for-you-smoke.mjs",
    "smoke:release-f-mobile-foundation": "node scripts/release-f-mobile-foundation-smoke.mjs",
    "smoke:release-f-mobile-social": "node scripts/release-f-mobile-social-smoke.mjs",
    "smoke:release-f-mobile-reliability": "node scripts/release-f-mobile-reliability-smoke.mjs",
    "smoke:release-g-cross-platform-qa": "node scripts/release-g-cross-platform-qa-smoke.mjs",
    "smoke:release-g-hardening": "node scripts/release-g-hardening-smoke.mjs",
    "smoke:chat-dashboard": "node scripts/chat-dashboard-smoke.mjs",
    "mobile:typecheck": "pnpm --filter @apps/mobile typecheck",
    "mobile:lint": "pnpm --filter @apps/mobile lint",
    "mobile:test": "pnpm --filter @apps/mobile test",
    "mobile:config-check": "pnpm --filter @apps/mobile config-check",
    "mobile:export:android": "pnpm --filter @apps/mobile export:android",
    "mobile:export:ios": "pnpm --filter @apps/mobile export:ios",
    "mobile:check": "pnpm --filter @apps/mobile check",
    "mobile:release-readiness": "node scripts/mobile-release-readiness-check.mjs",
    "verify:production-config": "node scripts/verify-production-config.mjs --target production",
    "verify:production-config:test": "node scripts/test-production-config-verifier.mjs",
    "verify:release-candidate": "node scripts/verify-release-candidate.mjs --dry-run",
    "verify:launch-gate": "node scripts/verify-launch-gate.mjs",
    "backup:mongo": "node scripts/mongo-backup.mjs",
    "backup:restore": "node scripts/mongo-restore.mjs",
    "backup:verify": "node scripts/mongo-backup-verify.mjs",
    "seed:demo-social": "node scripts/seed-demo-social.mjs",
    "import:pexels-demo-content": "node scripts/import-pexels-demo-content.mjs",
    "seed:beta-content": "node scripts/seed-beta-content.mjs",
    "seed:beta-content:dry-run": "node scripts/seed-beta-content.mjs --dry-run",
    "seed:beta-content:apply": "node scripts/seed-beta-content.mjs --apply",
    "seed:beta-content:report": "node scripts/seed-beta-content.mjs --report",
    "test:beta-content": "vitest run scripts/beta-content",
    "deploy": "turbo run deploy",
    "docker:build": "docker-compose -f docker-compose.dev.yml build",
    "docker:up": "docker-compose -f docker-compose.dev.yml up",
    "docker:down": "docker-compose -f docker-compose.dev.yml down",
    "docker:full:up": "docker compose -f docker-compose.full.yml up -d --build",
    "docker:full:down": "docker compose -f docker-compose.full.yml down",
    "docker:full:logs": "docker compose -f docker-compose.full.yml logs -f --tail=100",
    "docker:full:up:legacy": "docker-compose -f docker-compose.full.yml up -d --build",
    "docker:full:down:legacy": "docker-compose -f docker-compose.full.yml down",
    "docker:full:logs:legacy": "docker-compose -f docker-compose.full.yml logs -f --tail=100"
  },
  "devDependencies": {
    "dotenv-cli": "^11.0.0",
    "eslint": "^8.57.0",
    "mongodb": "^6.3.0",
    "prettier": "^3.2.5",
    "turbo": "^2.6.0",
    "vitest": "^1.2.1"
  },
  "engines": {
    "node": ">=20.19.4",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@8.15.0",
  "dependencies": {
    "dotenv": "^17.2.3"
  },
  "main": "index.js",
  "keywords": [],
  "author": "",
  "license": "ISC"
}
